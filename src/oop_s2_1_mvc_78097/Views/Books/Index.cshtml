@model oop_s2_1_mvc_78097.ViewModels.BookFilterViewModel

@{
    ViewData["Title"] = "Books";
}

<h1 class="mb-4">Books</h1>

<div class="mb-3">
    <a asp-action="Create" class="btn btn-primary">Create New Book</a>
</div>

<form method="get" class="row g-3 mb-4">
    <div class="col-md-4">
        <label class="form-label">Search by Title or Author</label>
        <input type="text" name="searchTerm" value="@Model.SearchTerm" class="form-control" />
    </div>

    <div class="col-md-3">
        <label class="form-label">Category</label>
        <select name="category" class="form-select">
            <option value="">All Categories</option>
            @foreach (var category in Model.Categories)
            {
                if (Model.Category == category)
                {
            <option value="@category" selected>@category</option>
                }
                else
                {
            <option value="@category">@category</option>
                }
            }
        </select>
    </div>

    <div class="col-md-3">
        <label class="form-label">Availability</label>
        <select name="availability" class="form-select">
            @if (Model.Availability == "All")
            {
            <option value="All" selected>All</option>
            }
            else
            {
            <option value="All">All</option>
            }

            @if (Model.Availability == "Available")
            {
            <option value="Available" selected>Available</option>
            }
            else
            {
            <option value="Available">Available</option>
            }

            @if (Model.Availability == "OnLoan")
            {
            <option value="OnLoan" selected>On Loan</option>
            }
            else
            {
            <option value="OnLoan">On Loan</option>
            }
        </select>
    </div>

    <div class="col-md-2 d-flex align-items-end">
        <button type="submit" class="btn btn-success w-100">Filter</button>
    </div>
</form>

<table class="table table-striped table-bordered">
    <thead class="table-light">
        <tr>
            <th>Title</th>
            <th>Author</th>
            <th>ISBN</th>
            <th>Category</th>
            <th>Availability</th>
            <th style="width: 220px;">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Books)
        {
        <tr>
            <td>@item.Title</td>
            <td>@item.Author</td>
            <td>@item.Isbn</td>
            <td>@item.Category</td>
            <td>
                @if (item.IsAvailable)
                    {
                <span class="badge bg-success">Available</span>
                    }
                    else
                    {
                <span class="badge bg-danger">On Loan</span>
                    }
            </td>
            <td>
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
            </td>
        </tr>
        }
    </tbody>
</table>