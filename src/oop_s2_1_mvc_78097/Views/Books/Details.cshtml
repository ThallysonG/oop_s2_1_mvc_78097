@model oop_s2_1_mvc_78097.Models.Book

@{
    ViewData["Title"] = "Book Details";

    var activeLoan = Model.Loans?.FirstOrDefault(l => l.ReturnedDate == null);
    var borrowedBy = activeLoan?.Member?.FullName ?? "-";
    var borrowedEmail = activeLoan?.Member?.Email ?? "-";
}

<h1 class="mb-4">Book Details</h1>

<table class="table table-bordered table-striped">
    <thead class="table-light">
        <tr>
            <th>Title</th>
            <th>Author</th>
            <th>ISBN</th>
            <th>Category</th>
            <th>Availability</th>
            <th>Borrowed By</th>
            <th>Member Email</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td>@Model.Title</td>
            <td>@Model.Author</td>
            <td>@Model.Isbn</td>
            <td>@Model.Category</td>
            <td>
                @if (Model.IsAvailable)
                {
                    <span class="badge bg-success">Available</span>
                }
                else
                {
                    <span class="badge bg-danger">On Loan</span>
                }
            </td>
            <td>
                @if (!Model.IsAvailable)
                {
                    @borrowedBy
                }
                else
                {
                    <span>-</span>
                }
            </td>
            <td>
                @if (!Model.IsAvailable)
                {
                    @borrowedEmail
                }
                else
                {
                    <span>-</span>
                }
            </td>
        </tr>
    </tbody>
</table>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>