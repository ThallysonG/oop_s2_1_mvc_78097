@model IEnumerable<oop_s2_1_mvc_78097.Models.Loan>

    @{
    ViewData["Title"] = "Loans";
    }

    <h1 class="mb-4">Loans</h1>

    <div class="mb-3">
        <a asp-action="Create" class="btn btn-primary">Create Loan</a>
    </div>

    <table class="table table-striped table-bordered">
        <thead class="table-light">
            <tr>
                <th>Book</th>
                <th>Member</th>
                <th>Loan Date</th>
                <th>Due Date</th>
                <th>Returned Date</th>
                <th>Status</th>
                <th style="width: 260px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var loan in Model)
        {
            var isOverdue = loan.ReturnedDate == null && loan.DueDate.Date < DateTime.Today;
            var isActive = loan.ReturnedDate == null;

            <tr>
                <td>@loan.Book?.Title</td>
                <td>@loan.Member?.FullName</td>
                <td>@loan.LoanDate.ToString("dd/MM/yyyy")</td>
                <td>@loan.DueDate.ToString("dd/MM/yyyy")</td>
                <td>@(loan.ReturnedDate?.ToString("dd/MM/yyyy") ?? "-")</td>
                <td>
                    @if (loan.ReturnedDate != null)
                    {
                    <span class="badge bg-success">Returned</span>
                    }
                    else if (isOverdue)
                    {
                    <span class="badge bg-danger">Overdue</span>
                    }
                    else
                    {
                    <span class="badge bg-warning text-dark">Active</span>
                    }
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@loan.Id" class="btn btn-sm btn-info">Details</a>

                    @if (isActive)
                    {
                    <form asp-action="MarkReturned" asp-route-id="@loan.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-success">Mark Returned</button>
                    </form>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
