@model oop_s2_1_mvc_78097.ViewModels.RoleManagementViewModel

@{
    ViewData["Title"] = "Role Management";
}

<h1 class="mb-4">Role Management</h1>

@if (TempData["ErrorMessage"] != null)
{
<div class="alert alert-danger">
    @TempData["ErrorMessage"]
</div>
}

<div class="row">
    <div class="col-md-5">
        <div class="card shadow-sm mb-4">
            <div class="card-header">
                <strong>Create New Role</strong>
            </div>
            <div class="card-body">
                <form asp-action="CreateRole" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="NewRoleName" class="form-label">Role Name</label>
                        <input asp-for="NewRoleName" class="form-control" />
                        <span asp-validation-for="NewRoleName" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary">Create Role</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-header">
                <strong>Existing Roles</strong>
            </div>
            <div class="card-body">
                @if (Model.Roles.Any())
                {
                <table class="table table-striped table-bordered mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Role Name</th>
                            <th style="width: 150px;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var role in Model.Roles)
                            {
                        <tr>
                            <td>@role</td>
                            <td>
                                @if (role == "Admin")
                                        {
                                <span class="text-muted">Protected</span>
                                        }
                                        else
                                        {
                                <form asp-action="DeleteRole" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="roleName" value="@role" />
                                    <button type="submit" class="btn btn-sm btn-danger">
                                        Delete
                                    </button>
                                </form>
                                        }
                            </td>
                        </tr>
                            }
                    </tbody>
                </table>
                }
                else
                {
                <p>No roles found.</p>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}