@model IEnumerable<CommunityLibraryDesk.Models.Loan>

@{
    ViewData["Title"] = "Loans";
}

<h1>Loans</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">New Loan</a>
</p>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Book</th>
            <th>Member</th>
            <th>Loan Date</th>
            <th>Due Date</th>
            <th>Returned Date</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var loan in Model)
        {
            <tr>
                <td>@loan.Book?.Title</td>
                <td>@loan.Member?.FullName</td>
                <td>@loan.LoanDate.ToShortDateString()</td>
                <td>@loan.DueDate.ToShortDateString()</td>
                <td>@(loan.ReturnedDate?.ToShortDateString() ?? "-")</td>
                <td>
                    @if (loan.ReturnedDate != null)
                    {
                        <span class="badge bg-success">Returned</span>
                    }
                    else if (loan.IsOverdue)
                    {
                        <span class="badge bg-danger">Overdue</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Active</span>
                    }
                </td>
                <td>
                    @if (loan.ReturnedDate == null)
                    {
                        <form asp-action="MarkReturned" method="post">
                            <input type="hidden" name="id" value="@loan.Id" />
                            <button type="submit" class="btn btn-sm btn-success">Mark returned</button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>