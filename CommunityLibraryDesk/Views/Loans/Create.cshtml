@model CommunityLibraryDesk.Models.ViewModels.CreateLoanViewModel

@{
    ViewData["Title"] = "Create Loan";
}

<h1>Create Loan</h1>

<form asp-action="Create" method="post">
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="BookId" class="form-label"></label>
        <select asp-for="BookId" asp-items="Model.AvailableBooks" class="form-select"></select>
    </div>

    <div class="mb-3">
        <label asp-for="MemberId" class="form-label"></label>
        <select asp-for="MemberId" asp-items="Model.Members" class="form-select"></select>
    </div>

    <div class="mb-3">
        <label asp-for="LoanDate" class="form-label"></label>
        <input asp-for="LoanDate" type="date" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="DueDate" class="form-label"></label>
        <input asp-for="DueDate" type="date" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
</form>