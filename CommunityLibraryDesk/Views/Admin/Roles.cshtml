@model CommunityLibraryDesk.Models.ViewModels.RoleManagementViewModel

@{
    ViewData["Title"] = "Role Management";
}

<h1>Role Management</h1>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<form asp-action="CreateRole" method="post" class="mb-4">
    <div class="input-group">
        <input asp-for="NewRoleName" class="form-control" placeholder="New role name" />
        <button type="submit" class="btn btn-primary">Create Role</button>
    </div>
</form>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Role</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var role in Model.Roles)
        {
            <tr>
                <td>@role.Name</td>
                <td>
                    @if (role.Name != "Admin")
                    {
                        <form asp-action="DeleteRole" method="post">
                            <input type="hidden" name="roleName" value="@role.Name" />
                            <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>